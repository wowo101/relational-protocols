---
import "../styles/global.css";
import { buildGraphData } from "../lib/buildGraphData";
import VaultGraph from "../components/diagrams/VaultGraph.jsx";

const { nodes, edges } = await buildGraphData();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>A relational protocol architecture for Fabric</title>
    <style>body { margin: 0; overflow: hidden; }</style>
  </head>
  <body style={{ color: "var(--color-text-primary, #2c2c2a)" }}>
    <VaultGraph
      client:load
      nodes={nodes}
      edges={edges}
      basePath={import.meta.env.BASE_URL}
    />
  </body>
</html>
