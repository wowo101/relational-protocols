---
import "../../styles/global.css";
import { getCollection, render } from "astro:content";
import NoteLayout from "../../layouts/NoteLayout.astro";
import { buildGraphData, toSlug } from "../../lib/buildGraphData";

export async function getStaticPaths() {
  const pages = await getCollection("pages");
  return pages
    .filter((n) => n.data.order > 0)
    .map((note) => ({
      params: { slug: toSlug(note.id) },
      props: { note },
    }));
}

const { note } = Astro.props;
const allNotes = await getCollection("pages");
const { Content } = await render(note);

const { nodes, edges } = await buildGraphData();
const currentId = note.id;
const neighbourIds = new Set<string>();
for (const e of edges) {
  if (e.source === currentId) neighbourIds.add(e.target);
  if (e.target === currentId) neighbourIds.add(e.source);
}
const connected = nodes
  .filter((n) => neighbourIds.has(n.id))
  .sort((a, b) => a.id.localeCompare(b.id));
---

<NoteLayout
  title={note.id}
  order={note.data.order}
  tags={note.data.tags}
  allNotes={allNotes}
  connected={connected}
  currentSlug={toSlug(note.id)}
>
  <Content />
</NoteLayout>
