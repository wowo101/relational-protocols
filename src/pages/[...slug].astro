---
import "../styles/global.css";
import { getCollection } from "astro:content";
import { buildGraphData, toSlug } from "../lib/buildGraphData";
import VaultGraph from "../components/diagrams/VaultGraph.jsx";

export async function getStaticPaths() {
  const pages = await getCollection("pages");
  return pages
    .filter((n) => n.data.order > 0)
    .map((note) => ({
      params: { slug: toSlug(note.id) },
      props: { slug: toSlug(note.id) },
    }));
}

const { slug } = Astro.props;
const { nodes, edges } = await buildGraphData();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>A relational protocol architecture for Fabric</title>
    <style>body { margin: 0; overflow: hidden; }</style>
  </head>
  <body style={{ color: "var(--color-text-primary, #2c2c2a)" }}>
    <VaultGraph
      client:load
      nodes={nodes}
      edges={edges}
      basePath={import.meta.env.BASE_URL}
      initialSlug={slug}
    />
  </body>
</html>
