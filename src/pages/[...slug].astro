---
import { getCollection, render } from "astro:content";
import NoteLayout from "../layouts/NoteLayout.astro";

export async function getStaticPaths() {
  const pages = await getCollection("pages");
  return pages
    .filter((n) => n.data.order > 0)
    .map((note) => {
      const slug = note.id.toLowerCase().replace(/\s+/g, "-");
      return { params: { slug }, props: { note } };
    });
}

const { note } = Astro.props;
const allNotes = await getCollection("pages");
const { Content } = await render(note);
---

<NoteLayout title={note.id} order={note.data.order} tags={note.data.tags} allNotes={allNotes}>
  <Content />
</NoteLayout>
