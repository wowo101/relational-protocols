---
import "../styles/global.css";
import { toSlug } from "../lib/buildGraphData";
import { CATEGORY_COLORS, VISITED_STORAGE_KEY } from "../lib/constants";

const { title, order, tags, allNotes, connected, currentSlug } = Astro.props;

const sorted = allNotes
  .filter((n) => n.data.order > 0)
  .sort((a, b) => a.data.order - b.data.order);

const currentIndex = sorted.findIndex((n) => n.data.order === order);
const prev = currentIndex > 0 ? sorted[currentIndex - 1] : null;
const next = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;

function noteHref(id: string) {
  return `${import.meta.env.BASE_URL}/${toSlug(id)}/`;
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} – Fabric</title>
  </head>
  <body>
    <article
      class="max-w-2xl mx-auto px-4 py-10 text-base"
      style={{ color: "var(--color-text-primary, #2c2c2a)" }}
    >
      <header class="mb-10">
        <a
          href={`${import.meta.env.BASE_URL}/`}
          class="text-sm opacity-50 hover:opacity-80 mb-4 inline-block"
          >&larr; Home</a
        >
        <h1 class="text-2xl font-medium tracking-tight">{title}</h1>
        {tags && tags.length > 0 && (
          <div class="mt-3 flex gap-2">
            {tags.map((tag: string) => {
              const c = CATEGORY_COLORS[tag];
              if (!c) return null;
              return (
                <span
                  class="inline-block text-xs font-medium px-2.5 py-0.5 rounded-full"
                  style={{ backgroundColor: c.fill + "20", color: c.fill }}
                >
                  {tag}
                </span>
              );
            })}
          </div>
        )}
      </header>

      <section class="mb-12 leading-relaxed">
        <slot />
      </section>

      {connected && connected.length > 0 && (
        <div
          class="mt-8 pt-6 border-t text-sm"
          style={{ borderColor: "var(--color-border-tertiary, #d3d1c7)" }}
        >
          <span class="opacity-50">Connected: </span>
          {connected.map((n, i) => (
            <>
              <a href={noteHref(n.id)} class="opacity-60 hover:opacity-100">{n.id}</a>
              {i < connected.length - 1 && <span class="opacity-30"> · </span>}
            </>
          ))}
        </div>
      )}

      <nav
        class="mt-6 pt-6 border-t flex justify-between text-sm"
        style={{ borderColor: "var(--color-border-tertiary, #d3d1c7)" }}
      >
        {prev ? (
          <a href={noteHref(prev.id)} class="opacity-60 hover:opacity-100">
            &larr; {prev.id}
          </a>
        ) : (
          <span />
        )}
        {next ? (
          <a href={noteHref(next.id)} class="opacity-60 hover:opacity-100 text-right">
            {next.id} &rarr;
          </a>
        ) : (
          <span />
        )}
      </nav>
    </article>

    <script define:vars={{ currentSlug, visitedKey: VISITED_STORAGE_KEY }}>
      try {
        const visited = JSON.parse(localStorage.getItem(visitedKey) || "[]");
        if (!visited.includes(currentSlug)) {
          visited.push(currentSlug);
          localStorage.setItem(visitedKey, JSON.stringify(visited));
        }
      } catch {}
    </script>
  </body>
</html>
